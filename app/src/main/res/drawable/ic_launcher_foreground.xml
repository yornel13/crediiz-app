        android:scaleX="0.58"
        android:scaleY="0.58"
        android:translateX="-5"
        android:pivotX="54"
        android:pivotY="54">

        <!-- Handset, scaled and centered -->
        <group
            android:scaleX="3.0"
            android:scaleY="3.0"
            android:translateX="18"
            android:translateY="26">
            <path
                android:fillColor="#FFFFFF"
