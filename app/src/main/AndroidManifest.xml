<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- SIP audio capture (mic) and routing -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Battery optimization (Samsung One UI is aggressive about killing services) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Boot receiver (re-schedule WorkManager + alarms after reboot) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Notifications (follow-up reminders + sync status + foreground service) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service (keep call tracking alive during active calls) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Exact alarms for follow-up reminders -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".CallsAgentApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallsAgends"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CallsAgends">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Mandatory onboarding gate — non-skippable while requirements are missing. -->
        <activity
            android:name=".presentation.onboarding.OnboardingActivity"
            android:exported="false"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.CallsAgends" />

        <!-- Custom in-call UI launched by CallsInCallService. Lock-screen
             friendly so it surfaces over a locked device. Honors the
             system orientation — no lock. -->
        <activity
            android:name=".presentation.incall.InCallActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.CallsAgends" />

        <!-- SIP call foreground service. type=microphone keeps the
             mic alive when the agent backgrounds the app during a
             call (Android 14+ requirement). -->
        <service
            android:name=".service.SipCallForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!--
          Disable WorkManager's eager auto-initialization via androidx.startup.
          Reason: our SyncWorker is a @HiltWorker built by HiltWorkerFactory,
          but the startup ContentProvider runs BEFORE the Application.onCreate
          finishes injecting Hilt deps — WorkManager would init with the
          default factory and fail to instantiate SyncWorker (NoSuchMethodException
          on the 2-arg constructor).

          With this removed, WorkManager initializes lazily on first
          getInstance() call and picks up our Configuration.Provider from
          CallsAgentApp.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
